{
	"useTabs": true,
	"tabWidth": 5,
	"printWidth": 80,
	"singleQuote": true,
	"trailingComma": "none",
	"plugins": ["prettier-plugin-svelte"],
	"overrides": [
		{
			"files": "*.svelte",
			"options": {
				"parser": "svelte"
			}
		},
		{
			"files": "*.ts",
			"options": {
				"parser": "typescript"
			}
		}
	]
}
